.controls {    
    text-align: center;
    padding: 1em;

    margin: 0;
    margin-top: auto;

    button {
        color: white;
        padding: 10px 20px;
        border: none;
        cursor: pointer;

        height: 5em;
        width: 5em;
                
        &.start {
            background-color: #4CAF50;
        }

        &.stop  {
            background-color: tomato;
        }

        &.pause {
            background-color: #f0ad4e;
        }        
    }
}